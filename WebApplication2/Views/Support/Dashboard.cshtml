@{
    ViewBag.Title = "Support Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Support Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            background: #f4f7fc;
            font-family: 'Segoe UI';
        }

        .sidebar {
            position: fixed;
            width: 250px;
            height: 100vh;
            background: #1e3a8a;
            color: white;
            padding-top: 20px;
            overflow-y: auto;
        }

            .sidebar h3 {
                text-align: center;
                margin-bottom: 30px;
            }

            .sidebar a {
                display: block;
                color: white;
                text-decoration: none;
                padding: 14px 25px;
                transition: 0.3s;
            }

                .sidebar a:hover {
                    background: #2563eb;
                }

        .content {
            margin-left: 250px;
            padding: 30px;
        }

        .welcome-box {
            background: white;
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 25px;
            box-shadow: 0px 3px 10px rgba(0,0,0,0.1);
        }

        .card-box {
            border-radius: 15px;
            color: white;
            padding: 25px;
            text-align: center;
            box-shadow: 0px 5px 15px rgba(0,0,0,.1);
        }

            .card-box h2 {
                margin: 0;
                font-size: 35px;
                font-weight: bold;
            }

            .card-box p {
                margin-top: 10px;
                font-size: 16px;
            }

        .quick-actions {
            background: white;
            padding: 20px;
            margin-top: 30px;
            border-radius: 15px;
            box-shadow: 0px 3px 10px rgba(0,0,0,0.1);
        }

            .quick-actions .btn {
                margin: 5px;
            }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <div class="sidebar">

        <h3>🎧 BMS Support</h3>

        <a href="/Support/Dashboard">📊 Dashboard</a>

        <a href="/Support/Customers">👥 Customers</a>

        <a href="/Support/Accounts">🏦 Accounts</a>

        <a href="/Support/Documents">📄 Documents</a>

        <a href="/Support/CardIssues">💳 Card Issues</a>

        <a href="/Support/Logout">🚪 Logout</a>

    </div>

    <!-- Main Content -->
    <div class="content">

        <div class="welcome-box">
            <h2>Welcome Support Officer 👋</h2>

            <p>
                Manage customer accounts,
                documents and debit card issues.
            </p>
        </div>

        <!-- Statistics -->
        <div class="row g-4">

            <div class="col-md-3">
                <div class="card-box bg-primary">
                    <h2>@ViewBag.TotalCustomers</h2>
                    <p>Customers</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card-box bg-success">
                    <h2>@ViewBag.TotalAccounts</h2>
                    <p>Accounts</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card-box bg-warning">
                    <h2>@ViewBag.TotalDocuments</h2>
                    <p>Documents</p>
                </div>
            </div>

        </div>

        <!-- Quick Actions -->
        <div class="quick-actions">

            <h4>⚡ Quick Actions</h4>

            <hr />

            <a href="/Support/Customers" class="btn btn-primary">
                👥 View Customers
            </a>

            <a href="/Support/Accounts" class="btn btn-success">
                🏦 View Accounts
            </a>

            <a href="/Support/Documents" class="btn btn-warning">
                📄 View Documents
            </a>


        </div>

    </div>

</body>
</html>