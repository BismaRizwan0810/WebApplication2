@model IEnumerable<WebApplication2.Models.DebitCard>

@{
    ViewBag.Title = "Card Issues";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Card Issues</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f4f7fc;
            font-family: 'Segoe UI';
        }

        .box {
            width: 90%;
            margin: 40px auto;
            background: white;
            padding: 25px;
            border-radius: 12px;
        }
    </style>
</head>

<body>

    <div class="box">

        <h3>💳 Card Issues</h3>

        <table class="table table-bordered table-hover mt-3">

            <thead class="table-dark">
                <tr>
                    <th>Card Number</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.CardNumber</td>

                        <td>
                            <span class="badge bg-warning">
                                @item.Status
                            </span>
                        </td>

                        <td>
                            <a href="/Support/ResolveCard/@item.CardID"
                               class="btn btn-success btn-sm">
                                Resolve
                            </a>
                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>

</body>
</html>