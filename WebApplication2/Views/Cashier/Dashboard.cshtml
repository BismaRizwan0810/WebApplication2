@{
    ViewBag.Title = "Cashier Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Cashier Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            background: #f4f7fc;
            font-family: 'Segoe UI';
        }

        /* SIDEBAR (same admin style) */
        .sidebar {
            position: fixed;
            width: 250px;
            height: 100vh;
            background: #1e3a8a;
            color: white;
            padding-top: 20px;
        }

            .sidebar h3 {
                text-align: center;
                margin-bottom: 30px;
            }

            .sidebar a {
                display: block;
                color: white;
                text-decoration: none;
                padding: 14px 25px;
                transition: 0.3s;
            }

                .sidebar a:hover {
                    background: #2563eb;
                }

        /* CONTENT */
        .content {
            margin-left: 250px;
            padding: 30px;
        }

        .welcome-box {
            background: white;
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 25px;
            box-shadow: 0px 3px 10px rgba(0,0,0,0.1);
        }

        .card-box {
            border-radius: 15px;
            color: white;
            padding: 25px;
            text-align: center;
            box-shadow: 0px 5px 15px rgba(0,0,0,.1);
        }

            .card-box h2 {
                font-size: 35px;
                font-weight: bold;
            }

            .card-box p {
                margin-top: 10px;
            }

        .quick-actions {
            background: white;
            padding: 20px;
            margin-top: 30px;
            border-radius: 15px;
            box-shadow: 0px 3px 10px rgba(0,0,0,0.1);
        }

        .btn {
            margin: 5px;
        }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">

        <h3>🏦 Cashier Panel</h3>

        <a href="/Cashier/Dashboard">📊 Dashboard</a>

        <a href="/Transactions/Create">📜 Transactions</a>
        <a href="/Transactions/GenerateSlip">🧾 Generate Slip</a>

        <a href="/Beneficiaries/Index">👨‍👩‍👧 Beneficiaries</a>

        <a href="/Home/Logout">🚪 Logout</a>

    </div>

    <!-- MAIN CONTENT -->
    <div class="content">

        <div class="welcome-box">
            <h2>Welcome Cashier 👋</h2>
            <p>
                Handle deposits, withdrawals, transfers and generate transaction slips.
            </p>
        </div>

        <!-- STATS -->
        <div class="row g-4">

            <div class="col-md-4">
                <div class="card-box bg-primary">
                    <h2>@ViewBag.TotalTransactions</h2>
                    <p>Total Transactions</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-box bg-success">
                    <h2>@ViewBag.TodayTransactions</h2>
                    <p>Today Transactions</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-box bg-warning">
                    <h2>@ViewBag.TotalBeneficiaries</h2>
                    <p>Beneficiaries</p>
                </div>
            </div>

        </div>

        <!-- QUICK ACTIONS -->
        <div class="quick-actions">

            <h4>⚡ Quick Actions</h4>
            <hr />

            <a href="/Transactions/Create" class="btn btn-primary">💳 New Transaction</a>
            <a href="/Transactions/Index" class="btn btn-dark">📜 View Transactions</a>
            <a href="/Beneficiaries/Index" class="btn btn-warning">👨‍👩‍👧 View Beneficiaries</a>

        </div>

    </div>

</body>
</html>