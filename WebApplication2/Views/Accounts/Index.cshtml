@model IEnumerable<WebApplication2.Models.Account>

@{
    ViewBag.Title = "Index";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        background: #eef2f7;
        font-family: "Segoe UI";
    }

    .page-header {
        background: linear-gradient(135deg, #0f172a, #1e3a8a);
        color: white;
        padding: 20px;
        border-radius: 12px;
        margin: 20px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    }

    .card-box {
        margin: 20px;
        background: white;
        border-radius: 12px;
        padding: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.06);
    }

    table {
        border-radius: 10px;
        overflow: hidden;
    }

    thead {
        background: #111827;
        color: white;
    }

        thead th {
            font-size: 13px;
            text-transform: uppercase;
            padding: 14px;
            border: none !important;
        }

    tbody td {
        font-size: 14px;
        padding: 12px !important;
        vertical-align: middle;
    }

    tbody tr:hover {
        background: #f1f5f9;
        transition: 0.2s;
    }

    /* ACTION BUTTON FIX */
    td a {
        text-decoration: none;
        padding: 5px 10px;
        border-radius: 6px;
        font-size: 12px;
        margin-right: 6px;
        display: inline-block;
    }

        td a:last-child {
            margin-right: 0;
        }

        td a[href*="Edit"] {
            background: #f59e0b;
            color: white;
        }

        td a[href*="Details"] {
            background: #3b82f6;
            color: white;
        }

        td a[href*="Delete"] {
            background: #ef4444;
            color: white;
        }

        td a:hover {
            opacity: 0.85;
        }

    .create-link {
        display: inline-block;
        margin: 20px;
        padding: 8px 14px;
        background: #16a34a;
        color: white;
        border-radius: 8px;
        text-decoration: none;
        font-size: 13px;
    }

        .create-link:hover {
            background: #15803d;
        }
</style>

<div class="page-header">
    <h3>🏦 Account Management</h3>
    <p class="mb-0">Manage all bank accounts</p>
</div>

<a href="/Accounts/Create" class="create-link">➕ Create New</a>

<div class="card-box">

    <table class="table table-bordered table-hover">

        <tr>
            <th>@Html.DisplayNameFor(model => model.AccountNumber)</th>
            <th>@Html.DisplayNameFor(model => model.Balance)</th>
            <th>@Html.DisplayNameFor(model => model.Status)</th>
            <th>@Html.DisplayNameFor(model => model.OpenDate)</th>
            <th>@Html.DisplayNameFor(model => model.AccountType.AccountTypeName)</th>
            <th>@Html.DisplayNameFor(model => model.Branch.BranchCode)</th>
            <th>@Html.DisplayNameFor(model => model.Customer.FirstName)</th>
            <th></th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.AccountNumber)</td>
                <td>@Html.DisplayFor(modelItem => item.Balance)</td>
                <td>@Html.DisplayFor(modelItem => item.Status)</td>
                <td>@Html.DisplayFor(modelItem => item.OpenDate)</td>
                <td>@Html.DisplayFor(modelItem => item.AccountType.AccountTypeName)</td>
                <td>@Html.DisplayFor(modelItem => item.Branch.BranchCode)</td>
                <td>@Html.DisplayFor(modelItem => item.Customer.FirstName)</td>

                <td>
                    @Html.ActionLink("Edit", "Edit", new { id = item.AccountID }) |
                    @Html.ActionLink("Details", "Details", new { id = item.AccountID }) |
                    @Html.ActionLink("Delete", "Delete", new { id = item.AccountID })
                </td>
            </tr>
        }

    </table>

    <div class="mt-3">
        <a href="@Session["DashboardUrl"]" class="btn btn-secondary">
            ← Back To Dashboard
        </a>

    </div>

</div>