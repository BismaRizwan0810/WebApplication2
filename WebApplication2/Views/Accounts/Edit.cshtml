@model WebApplication2.Models.Account

@{
    ViewBag.Title = "Edit Account";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        background: #eef2f7;
        font-family: "Segoe UI";
    }

    .page-header {
        background: linear-gradient(135deg, #0f172a, #1e3a8a);
        color: white;
        padding: 18px 22px;
        border-radius: 12px;
        margin: 20px;
    }

    .card-box {
        margin: 20px;
        background: white;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.06);
    }

    .form-group {
        margin-bottom: 15px;
    }

    label {
        font-weight: 600;
        margin-bottom: 5px;
    }

    .form-control {
        border-radius: 8px;
        padding: 10px;
    }

    .btn-primary, .btn-secondary {
        border-radius: 8px;
        padding: 8px 18px;
    }
</style>

<div class="page-header">
    <h3>✏️ Edit Account</h3>
    <small>Update account details</small>
</div>

<div class="card-box">

    @using (Html.BeginForm("Edit", "Accounts", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        @Html.HiddenFor(model => model.AccountID)

        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-group">
            <label>Customer</label>
            @Html.DropDownList("CustomerID", null, "-- Select Customer --", new { @class = "form-control" })
        </div>

        <div class="form-group">
            <label>Branch</label>
            @Html.DropDownList("BranchID", null, "-- Select Branch --", new { @class = "form-control" })
        </div>

        <div class="form-group">
            <label>Account Type</label>
            @Html.DropDownList("AccountTypeID", null, "-- Select Type --", new { @class = "form-control" })
        </div>

        <div class="form-group">
            <label>Account Number</label>
            @Html.EditorFor(model => model.AccountNumber, new { htmlAttributes = new { @class = "form-control" } })
        </div>

        <div class="form-group">
            <label>Balance</label>
            @Html.EditorFor(model => model.Balance, new { htmlAttributes = new { @class = "form-control" } })
        </div>

        <div class="form-group">
            <label>Status</label>
            @Html.EditorFor(model => model.Status, new { htmlAttributes = new { @class = "form-control" } })
        </div>

        <div class="form-group">
            <label>Open Date</label>
            @Html.EditorFor(model => model.OpenDate, new { htmlAttributes = new { @class = "form-control" } })
        </div>

        <div class="mt-3">
            <input type="submit" value="Update Account" class="btn btn-primary" />
            @Html.ActionLink("Back", "Index", null, new { @class = "btn btn-secondary ms-2" })
        </div>
    }

</div>