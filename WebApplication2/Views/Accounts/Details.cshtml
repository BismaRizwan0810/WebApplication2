@model WebApplication2.Models.Account

@{
    ViewBag.Title = "Details";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        background: #eef2f7;
        font-family: "Segoe UI";
    }

    .page-header {
        background: linear-gradient(135deg, #0f172a, #1e3a8a);
        color: white;
        padding: 18px 22px;
        border-radius: 12px;
        margin: 20px;
    }

    .card-box {
        margin: 20px;
        background: white;
        border-radius: 12px;
        padding: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.06);
    }

    dl {
        margin: 0;
    }

    dt {
        font-weight: 600;
        color: #334155;
        margin-top: 12px;
    }

    dd {
        margin-bottom: 10px;
        padding: 8px 12px;
        background: #f8fafc;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
    }

    .btn {
        border-radius: 8px;
        padding: 6px 14px;
        font-size: 13px;
    }

    .action-bar {
        margin-top: 20px;
    }
</style>

<div class="page-header">
    <h3>🏦 Account Details</h3>
    <small>Complete account information</small>
</div>

<div class="card-box">

    <dl class="dl-horizontal">

        <dt>Account Number</dt>
        <dd>@Html.DisplayFor(model => model.AccountNumber)</dd>

        <dt>Balance</dt>
        <dd>@Html.DisplayFor(model => model.Balance)</dd>

        <dt>Status</dt>
        <dd>@Html.DisplayFor(model => model.Status)</dd>

        <dt>Open Date</dt>
        <dd>@Html.DisplayFor(model => model.OpenDate)</dd>

        <dt>Account Type</dt>
        <dd>@Html.DisplayFor(model => model.AccountType.AccountTypeName)</dd>

        <dt>Branch</dt>
        <dd>@Html.DisplayFor(model => model.Branch.BranchCode)</dd>

        <dt>Customer</dt>
        <dd>@Html.DisplayFor(model => model.Customer.FirstName)</dd>

    </dl>

    <div class="action-bar">
        @Html.ActionLink("Edit", "Edit", new { id = Model.AccountID }, new { @class = "btn btn-warning" })
        @Html.Raw(" ")
        @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary" })
    </div>

</div>