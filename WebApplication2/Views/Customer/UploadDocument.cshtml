@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Upload Document</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <style>
        body {
            background: #f4f7fc;
            font-family: 'Segoe UI';
        }

        .upload-card {
            max-width: 700px;
            margin: 60px auto;
            border-radius: 20px;
        }

        .card-icon {
            font-size: 60px;
        }

        .form-control,
        .form-select {
            border-radius: 10px;
        }

        .btn {
            border-radius: 10px;
        }
    </style>
</head>
<body>

    <div class="container">

        <div class="card shadow-lg border-0 upload-card">

            <div class="card-body p-5">

                <div class="text-center mb-4">

                    <div class="card-icon">📤</div>

                    <h2 class="text-success fw-bold mt-3">
                        Upload Document
                    </h2>

                    <p class="text-muted">
                        Upload CNIC, Passport, Utility Bills and other documents
                    </p>

                </div>

                <form method="post" enctype="multipart/form-data">

                    <div class="mb-3">

                        <label class="form-label fw-bold">
                            Document Type
                        </label>

                        <select name="documentType"
                                class="form-select">

                            <option>CNIC</option>
                            <option>Passport</option>
                            <option>Utility Bill</option>

                        </select>

                    </div>

                    <div class="mb-4">

                        <label class="form-label fw-bold">
                            Select File
                        </label>

                        <input type="file"
                               name="file"
                               class="form-control" />

                    </div>

                    <div class="d-flex gap-2">

                        <button type="submit"
                                class="btn btn-success flex-fill">
                            📤 Upload Document
                        </button>

                        <a href="/Customer/Dashboard"
                           class="btn btn-secondary flex-fill">
                            ← Back
                        </a>

                    </div>

                </form>

                @if (ViewBag.Message != null)
                {
                    <div class="alert alert-success mt-4 text-center">
                        @ViewBag.Message
                    </div>
                }

            </div>

        </div>

    </div>

</body>
</html>