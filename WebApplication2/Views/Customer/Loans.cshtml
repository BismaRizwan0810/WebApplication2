@model IEnumerable<WebApplication2.Models.Loan>

@{
    ViewBag.Title = "My Loans";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>My Loans</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: #f4f7fc;
            font-family: 'Segoe UI';
        }

        .container-box {
            width: 95%;
            margin: 40px auto;
            background: white;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0px 3px 10px rgba(0,0,0,.1);
        }

        h2 {
            color: #1e3a8a;
        }
    </style>
</head>
<body>

    <div class="container-box">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <h2>🏦 My Loans</h2>

            <a href="@Url.Action("Create", "Loans")"
               class="btn btn-success">
                ➕ Apply Loan
            </a>

        </div>

        <table class="table table-bordered table-striped">

            <thead class="table-dark">
                <tr>
                    <th>Loan ID</th>
                    <th>Loan Type</th>
                    <th>Amount</th>
                    <th>Duration (Months)</th>
                    <th>Status</th>
                    <th>Apply Date</th>
                </tr>
            </thead>

            <tbody>

                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.LoanID</td>
                            <td>
                                @(item.LoanType != null
        ? item.LoanType.LoanTypeName
        : "N/A")
                            </td>
                            <td>Rs. @item.Amount</td>
                            <td>@item.DurationMonths</td>
                            <td>
                                @if (item.Status == "Approved")
                                {
                                    <span class="badge bg-success">
                                        Approved
                                    </span>
                                }
                                else if (item.Status == "Rejected")
                                {
                                    <span class="badge bg-danger">
                                        Rejected
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">
                                        Pending
                                    </span>
                                }
                            </td>

                            <td>
                                @(item.ApplyDate.HasValue
                                  ? item.ApplyDate.Value.ToString("dd-MMM-yyyy")
                                  : "-")
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">
                            No Loans Found
                        </td>
                    </tr>
                }

            </tbody>

        </table>

        <a href="/Customer/Dashboard"
           class="btn btn-primary">
            Back To Dashboard
        </a>

    </div>

</body>
</html>