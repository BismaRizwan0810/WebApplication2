@{
    ViewBag.Title = "Customer Dashboard";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Customer Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            background: #f4f7fc;
            font-family: 'Segoe UI';
        }

        .sidebar {
            position: fixed;
            width: 250px;
            height: 100vh;
            background: #1e3a8a;
            color: white;
            padding-top: 20px;
        }

            .sidebar h3 {
                text-align: center;
                margin-bottom: 30px;
            }

            .sidebar a {
                display: block;
                color: white;
                text-decoration: none;
                padding: 14px 25px;
            }

                .sidebar a:hover {
                    background: #2563eb;
                }

        .content {
            margin-left: 250px;
            padding: 30px;
        }

        .card-box {
            border-radius: 15px;
            color: white;
            padding: 25px;
            text-align: center;
        }

            .card-box h2 {
                font-size: 35px;
                font-weight: bold;
            }
    </style>

</head>
<body>

    <div class="sidebar">

        <h3>🏦 BMS Customer</h3>

        <a href="/Customer/Dashboard">🏠 Dashboard</a>

        <a href="/Customer/MyAccount">👤 My Account</a>

        <a href="/Customer/Balance">💰 Balance</a>

        <a href="/Customer/Transactions">💳 Transactions</a>

        <a href="/Customer/DebitCards">💳 Debit Cards</a>

        <a href="/Customer/Loans">🏦 Loans</a>

        <a href="/Customer/Beneficiaries">👨‍👩‍👧 Beneficiaries</a>
        <a href="/Customer/UploadDocument">📄 Upload Documents</a>

        <a href="/Home/Logout">🚪 Logout</a>

    </div>

    <div class="content">

        <div class="bg-white p-4 rounded shadow-sm mb-4">
            <h2>Welcome @ViewBag.CustomerName 👋</h2>
            <p>Manage your banking services here.</p>
        </div>

        <div class="row g-4">

            <div class="col-md-3">
                <div class="card-box bg-primary">
                    <h2>@ViewBag.TotalAccounts</h2>
                    <p>Accounts</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card-box bg-success">
                    <h2>@ViewBag.TotalCards</h2>
                    <p>Debit Cards</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card-box bg-danger">
                    <h2>@ViewBag.TotalLoans</h2>
                    <p>Loans</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card-box bg-warning">
                    <h2>@ViewBag.TotalBeneficiaries</h2>
                    <p>Beneficiaries</p>
                </div>
            </div>

        </div>

    </div>

</body>
</html>