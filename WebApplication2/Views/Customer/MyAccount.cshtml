@model WebApplication2.Models.Customer

@{
    ViewBag.Title = "My Account";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>My Account</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f4f7fc;
            font-family: 'Segoe UI';
        }

        .container-box {
            max-width: 900px;
            margin: 40px auto;
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0px 3px 10px rgba(0,0,0,.1);
        }

        .title {
            margin-bottom: 25px;
            color: #1e3a8a;
        }
    </style>
</head>
<body>

    <div class="container-box">

        <h2 class="title">👤 My Account</h2>

        <table class="table table-bordered">

            <tr>
                <th>First Name</th>
                <td>@Model.FirstName</td>
            </tr>

            <tr>
                <th>Last Name</th>
                <td>@Model.LastName</td>
            </tr>

            <tr>
                <th>Father Name</th>
                <td>@Model.FatherName</td>
            </tr>

            <tr>
                <th>CNIC</th>
                <td>@Model.CNIC</td>
            </tr>

            <tr>
                <th>Gender</th>
                <td>@Model.Gender</td>
            </tr>

            <tr>
                <th>Date Of Birth</th>
                <td>@Model.DateOfBirth</td>
            </tr>

            <tr>
                <th>Phone</th>
                <td>@Model.Phone</td>
            </tr>

            <tr>
                <th>Email</th>
                <td>@Model.Email</td>
            </tr>

            <tr>
                <th>Address</th>
                <td>@Model.Address</td>
            </tr>

        </table>

        <a href="/Customer/Dashboard" class="btn btn-primary">
            Back To Dashboard
        </a>

    </div>

</body>
</html>