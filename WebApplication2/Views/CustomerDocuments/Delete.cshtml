@model WebApplication2.Models.CustomerDocument

@{
    ViewBag.Title = "Delete Document";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <!-- CARD -->
            <div class="card shadow-lg border-0 rounded-4">

                <!-- HEADER -->
                <div class="card-header bg-danger text-white text-center">
                    <h4 class="mb-0">🗑 Delete Customer Document</h4>
                </div>

                <!-- BODY -->
                <div class="card-body p-4 text-center">

                    <h5 class="text-danger fw-bold mb-3">
                        Are you sure you want to delete this document?
                    </h5>

                    <p class="text-muted mb-4">
                        This action cannot be undone.
                    </p>

                    <!-- DETAILS -->
                    <div class="row g-3 text-start">

                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">Document Type</small>
                                <div class="fw-semibold">
                                    @Model.DocumentType
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">File Name</small>
                                <div class="fw-semibold">
                                    @Model.FileName
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">Upload Date</small>
                                <div class="fw-semibold">
                                    @(Model.UploadDate.HasValue
                                        ? Model.UploadDate.Value.ToString("dd-MMM-yyyy")
                                        : "-")
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">Customer</small>
                                <div class="fw-semibold">
                                    @(Model.Customer != null ? Model.Customer.FirstName : "N/A")
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- ACTION BUTTONS -->
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()

                        <div class="d-flex justify-content-between mt-4">

                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                                ⬅ Cancel
                            </a>

                            <button type="submit" class="btn btn-danger px-4">
                                🗑 Delete Permanently
                            </button>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

</div>