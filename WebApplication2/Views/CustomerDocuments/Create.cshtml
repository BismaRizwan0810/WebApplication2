@model WebApplication2.Models.CustomerDocument

@{
    ViewBag.Title = "Upload Document";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-md-7">

            <div class="card shadow-lg border-0 rounded-4">

                <!-- HEADER -->
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0">📤 Upload Customer Document</h4>
                </div>

                <!-- BODY -->
                <div class="card-body p-4">

                    @using (Html.BeginForm("Create", "CustomerDocuments", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <!-- CUSTOMER -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Select Customer</label>
                            @Html.DropDownList("CustomerID", null, "-- Select Customer --",
                                new { @class = "form-control" })
                        </div>

                        <!-- DOCUMENT TYPE -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Document Type</label>
                            @Html.TextBoxFor(m => m.DocumentType,
                                new { @class = "form-control", placeholder = "CNIC / Bill / Salary Slip" })
                        </div>

                        <!-- FILE UPLOAD -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Select File</label>
                            <input type="file" name="file" class="form-control" />
                        </div>

                        <!-- INFO -->
                        <div class="alert alert-info">
                            Only PDF, JPG, PNG files allowed (recommended)
                        </div>

                        <!-- BUTTONS -->
                        <div class="d-flex justify-content-between mt-4">

                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                ⬅ Back
                            </a>

                            <button type="submit" class="btn btn-success px-4">
                                📤 Upload Document
                            </button>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

</div>