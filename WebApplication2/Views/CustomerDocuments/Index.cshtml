@{
    ViewBag.Title = "Customer Documents";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">

    <div class="text-center mb-5">
        <h2 class="fw-bold text-primary">📁 Customer Documents</h2>
        <p class="text-muted">Manage customer files and records</p>
    </div>

    <div class="row justify-content-center">

       

        <!-- VIEW -->
        <div class="col-md-5 mb-4">

            <a href="@Url.Action("IndexList", "CustomerDocuments")" class="text-decoration-none">

                <div class="card shadow-lg border-0 text-center p-5 hover-card">

                    <div style="font-size:60px;">📂</div>

                    <h4 class="mt-3 text-primary fw-bold">View Documents</h4>

                    <p class="text-muted">
                        Search and manage uploaded files
                    </p>

                    <span class="btn btn-primary mt-2">View</span>

                </div>

            </a>

        </div>

    </div>
</div>

<style>
    .hover-card {
        border-radius: 18px;
        transition: 0.3s;
    }

        .hover-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.2);
        }
</style>