@model IEnumerable<WebApplication2.Models.DebitCard>

@{
    ViewBag.Title = "Debit Cards";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">💳 Debit Card Management</h2>

        <a href="@Url.Action("Create")" class="btn btn-success">
            ➕ Issue New Card
        </a>
    </div>

    <!-- CARD -->
    <div class="card shadow border-0">

        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">📋 Card List</h5>
        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">
                        <tr>
                            <th>Card Number</th>
                            <th>Expiry Date</th>
                            <th>Status</th>
                            <th>Account Number</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <!-- MASK CARD NUMBER -->
                                    <td class="fw-semibold">
                                        **** **** **** @item.CardNumber.Substring(item.CardNumber.Length - 4)
                                    </td>

                                    <!-- EXPIRY DATE (FIXED ERROR) -->
                                    <td>
                                        @item.ExpiryDate.ToString("yyyy-MM")
                                    </td>

                                    <!-- STATUS -->
                                    <td>
                                        @if (item.Status == "Active")
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Blocked</span>
                                        }
                                    </td>

                                    <td>
                                        @item.Account.AccountNumber
                                    </td>

                                    <!-- ACTIONS -->
                                    <td class="text-center">

                                        <div class="btn-group">

                                            <a href="@Url.Action("Details", new { id = item.CardID })"
                                               class="btn btn-info btn-sm">
                                                👁 View
                                            </a>

                                            <a href="@Url.Action("Edit", new { id = item.CardID })"
                                               class="btn btn-warning btn-sm">
                                                ✏ Edit
                                            </a>

                                            <a href="@Url.Action("Delete", new { id = item.CardID })"
                                               class="btn btn-danger btn-sm">
                                                🗑 Delete
                                            </a>

                                            @if (item.Status == "Active")
                                            {
                                                <a href="@Url.Action("Block", new { id = item.CardID })"
                                                   class="btn btn-dark btn-sm">
                                                    🚫 Block
                                                </a>
                                            }
                                            else
                                            {
                                                <a href="@Url.Action("Unblock", new { id = item.CardID })"
                                                   class="btn btn-success btn-sm">
                                                    🔓 Unblock
                                                </a>
                                            }

                                        </div>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    No debit cards found.
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>
            <div class="mt-3">
                <a href="/Admin/Dashboard" class="btn btn-secondary">
                    ← Back To Dashboard
                </a>


            </div>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>