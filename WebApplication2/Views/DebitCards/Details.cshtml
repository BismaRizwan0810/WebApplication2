@model WebApplication2.Models.DebitCard

@{
    ViewBag.Title = "Debit Card Details";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-md-8 col-lg-6">

            <div class="card shadow-lg border-0 rounded-3">

                <!-- HEADER -->
                <div class="card-header bg-dark text-white text-center">
                    <h4 class="mb-0">💳 Debit Card Details</h4>
                </div>

                <div class="card-body p-4">

                    <!-- CARD NUMBER -->
                    <div class="mb-3 p-3 bg-light rounded">
                        <small class="text-muted">Card Number</small>
                        <div class="fw-bold fs-5">
                            **** **** **** @Model.CardNumber.Substring(Model.CardNumber.Length - 4)
                        </div>
                    </div>

                    <!-- EXPIRY -->
                    <div class="mb-3 p-3 bg-light rounded">
                        <small class="text-muted">Expiry Date</small>
                        <div class="fw-semibold">
                            @Model.ExpiryDate.ToString("yyyy-MM")
                        </div>
                    </div>

                    <!-- STATUS -->
                    <div class="mb-3 p-3 bg-light rounded">
                        <small class="text-muted">Status</small>
                        <div>
                            @if (Model.Status == "Active")
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Blocked</span>
                            }
                        </div>
                    </div>

                    <!-- ACCOUNT -->
                    <div class="mb-3 p-3 bg-light rounded">
                        <small class="text-muted">Account Number</small>
                        <div class="fw-semibold">
                            @Model.Account.AccountNumber
                        </div>
                    </div>

                    <!-- BUTTONS -->
                    <div class="d-flex justify-content-between mt-4">

                        <a href="@Url.Action("Index")"
                           class="btn btn-outline-secondary">
                            ⬅ Back
                        </a>

                        <a href="@Url.Action("Edit", new { id = Model.CardID })"
                           class="btn btn-warning">
                            ✏️ Edit
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>