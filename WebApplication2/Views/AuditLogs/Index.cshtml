@model IEnumerable<WebApplication2.Models.AuditLog>

@{
    ViewBag.Title = "Audit Logs";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container py-5">

    <!-- HEADER -->
    <div class="text-center mb-4">
        <h2 class="fw-bold text-dark">📊 Audit Logs</h2>
        <p class="text-muted">System activity tracking & security logs</p>
    </div>

    <!-- CARD -->
    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-dark text-white">
            📋 Activity Log History
        </div>

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">
                        <tr>
                            <th>Action</th>
                            <th>Date</th>
                            <th>IP Address</th>
                            <th>User</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <!-- ACTION -->
                                    <td>
                                        <span class="badge bg-primary">
                                            @item.ActionName
                                        </span>
                                    </td>

                                    <!-- DATE (FIXED) -->
                                    <td>
                                        @(item.ActionDate != null
                                            ? Convert.ToDateTime(item.ActionDate)
                                                .ToString("dd-MMM-yyyy hh:mm tt")
                                            : "-")
                                    </td>

                                    <!-- IP -->
                                    <td>
                                        <code>@item.IPAddress</code>
                                    </td>

                                    <!-- USER -->
                                    <td>
                                        @(item.User != null ? item.User.Username : "System")
                                    </td>

                                    <!-- ACTIONS -->
                                    <td class="text-center">

                                        <a href="@Url.Action("Details", "AuditLogs", new { id = item.LogID })"
                                           class="btn btn-sm btn-info">
                                            👁 View
                                        </a>

                                        <a href="@Url.Action("Delete", "AuditLogs", new { id = item.LogID })"
                                           class="btn btn-sm btn-danger">
                                            🗑 Delete
                                        </a>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    No audit logs found
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>