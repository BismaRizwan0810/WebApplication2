@{
    ViewBag.Title = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Bank Management System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI';
            background: linear-gradient(135deg, #0f172a, #1e3a8a, #0ea5e9);
            color: white;
        }

        /* HERO */
        .hero {
            text-align: center;
            padding: 110px 20px 70px;
        }

            .hero h1 {
                font-size: 55px;
                font-weight: 700;
            }

            .hero p {
                font-size: 18px;
                opacity: 0.85;
                margin-top: 10px;
            }

        .btn-login {
            margin-top: 25px;
            background: white;
            color: #1e3a8a;
            padding: 12px 32px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            display: inline-block;
            transition: 0.3s;
        }

            .btn-login:hover {
                background: #e2e8f0;
                transform: scale(1.05);
            }

        /* SECTION */
        .section {
            padding: 60px 40px;
        }

        .section-title {
            text-align: center;
            font-size: 28px;
            font-weight: 600;
            margin-bottom: 40px;
        }

        /* CARD STYLE */
        .card-box {
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.2);
            padding: 30px;
            border-radius: 18px;
            text-align: center;
            transition: 0.3s;
        }

            .card-box:hover {
                transform: translateY(-10px);
                background: rgba(255,255,255,0.15);
            }

        .card-icon {
            font-size: 35px;
            margin-bottom: 10px;
        }

        /* ABOUT */
        .about {
            text-align: center;
            max-width: 800px;
            margin: auto;
            font-size: 16px;
            opacity: 0.85;
        }

        /* FOOTER */
        .footer {
            text-align: center;
            padding: 25px;
            font-size: 14px;
            opacity: 0.7;
        }
    </style>
</head>

<body>

    <!-- HERO -->
    <div class="hero">
        <h1>🏦 Bank Management System</h1>
        <p>Secure • Smart • Modern Digital Banking Platform</p>

        <a href="/Login/Index" class="btn-login">🔐 Login to Continue</a>
    </div>

    <!-- FEATURES -->
    <div class="section">
        <div class="section-title">⚡ System Features</div>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="card-box">
                    <div class="card-icon">👤</div>
                    <h5>User Management</h5>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-box">
                    <div class="card-icon">🏦</div>
                    <h5>Accounts System</h5>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-box">
                    <div class="card-icon">💳</div>
                    <h5>Transactions</h5>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-box">
                    <div class="card-icon">📊</div>
                    <h5>Reports</h5>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-box">
                    <div class="card-icon">🔐</div>
                    <h5>Role Based Access</h5>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-box">
                    <div class="card-icon">🏠</div>
                    <h5>Loan Management</h5>
                </div>
            </div>

        </div>
    </div>

    <!-- ABOUT -->
    <div class="section">
        <div class="section-title">About System</div>

        <div class="about">
            This Bank Management System is a secure and scalable solution designed to manage users,
            customers, accounts, transactions, loans, and role-based access (Admin, Manager, Cashier, Customer).
            Built using ASP.NET MVC with Entity Framework and SQL Server.
        </div>
    </div>

    <!-- FOOTER -->
    <div class="footer">
        © 2026 Bank Management System | Academic Project
    </div>

</body>
</html>