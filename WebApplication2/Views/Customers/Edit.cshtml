@model WebApplication2.Models.Customer

@{
    ViewBag.Title = "Edit Customer";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        background: #eef2f7;
        font-family: "Segoe UI";
    }

    .header {
        background: linear-gradient(135deg, #1e3a8a, #2563eb);
        color: white;
        padding: 18px 22px;
        border-radius: 12px;
        margin: 20px;
    }

    .card-box {
        margin: 20px;
        background: white;
        border-radius: 12px;
        padding: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.06);
    }

    .form-label {
        font-weight: 500;
        color: #334155;
    }

    .form-control, .form-select {
        border-radius: 8px;
        padding: 10px;
    }

    .btn {
        border-radius: 8px;
        padding: 8px 18px;
    }

    .top-title {
        margin: 0;
        font-weight: 600;
    }

    .sub-text {
        opacity: 0.85;
        font-size: 13px;
    }
</style>

<div class="header">
    <h4 class="top-title">✏ Edit Customer</h4>
    <div class="sub-text">Update customer details carefully</div>
</div>

<div class="card-box">

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.CustomerID)

        <div class="row g-3">

            <div class="col-md-6">
                <label class="form-label">User</label>
                @Html.DropDownList("UserID", null, new { @class = "form-select" })
            </div>

            <div class="col-md-6">
                <label class="form-label">Branch</label>
                @Html.DropDownList("BranchID", null, new { @class = "form-select" })
            </div>

            <div class="col-md-6">
                <label class="form-label">First Name</label>
                @Html.EditorFor(m => m.FirstName, new { htmlAttributes = new { @class = "form-control" } })
            </div>

            <div class="col-md-6">
                <label class="form-label">Last Name</label>
                @Html.EditorFor(m => m.LastName, new { htmlAttributes = new { @class = "form-control" } })
            </div>

            <div class="col-md-6">
                <label class="form-label">Father Name</label>
                @Html.EditorFor(m => m.FatherName, new { htmlAttributes = new { @class = "form-control" } })
            </div>

            <div class="col-md-6">
                <label class="form-label">CNIC</label>
                @Html.EditorFor(m => m.CNIC, new { htmlAttributes = new { @class = "form-control" } })
            </div>

            <div class="col-md-6">
                <label class="form-label">Gender</label>
                @Html.EditorFor(m => m.Gender, new { htmlAttributes = new { @class = "form-control" } })
            </div>

            <div class="col-md-6">
                <label class="form-label">Date of Birth</label>
                @Html.EditorFor(m => m.DateOfBirth, new { htmlAttributes = new { @class = "form-control" } })
            </div>

            <div class="col-md-6">
                <label class="form-label">Phone</label>
                @Html.EditorFor(m => m.Phone, new { htmlAttributes = new { @class = "form-control" } })
            </div>

            <div class="col-md-6">
                <label class="form-label">Email</label>
                @Html.EditorFor(m => m.Email, new { htmlAttributes = new { @class = "form-control" } })
            </div>

            <div class="col-md-12">
                <label class="form-label">Address</label>
                @Html.EditorFor(m => m.Address, new { htmlAttributes = new { @class = "form-control" } })
            </div>

            <div class="col-md-6">
                <label class="form-label">Registration Date</label>
                @Html.EditorFor(m => m.RegistrationDate, new { htmlAttributes = new { @class = "form-control" } })
            </div>

        </div>

        <div class="mt-4 d-flex gap-2">
            <input type="submit" value="💾 Save Changes" class="btn btn-primary" />
            @Html.ActionLink("⬅ Back", "Index", null, new { @class = "btn btn-secondary" })
        </div>
    }

</div>