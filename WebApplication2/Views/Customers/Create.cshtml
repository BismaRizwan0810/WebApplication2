@model WebApplication2.Models.Customer

@{
    ViewBag.Title = "Add Customer";
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta charset="utf-8" />
    <title>Add Customer</title>

    ```
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: #f4f7fc;
            font-family: 'Segoe UI';
        }

        .card-box {
            max-width: 1000px;
            margin: 40px auto;
            background: white;
            border-radius: 20px;
            padding: 35px;
            box-shadow: 0 10px 30px rgba(0,0,0,.08);
        }

        .title {
            text-align: center;
            color: #1e40af;
            font-weight: bold;
            margin-bottom: 30px;
        }

        .form-control {
            border-radius: 10px;
            padding: 10px;
        }

        label {
            font-weight: 600;
            margin-bottom: 5px;
        }

        .btn-save {
            background: #2563eb;
            color: white;
            border: none;
            border-radius: 10px;
            padding: 12px;
            width: 100%;
            font-weight: 600;
        }

            .btn-save:hover {
                background: #1d4ed8;
            }

        .btn-back {
            margin-top: 10px;
            width: 100%;
        }
    </style>
    ```

</head>
<body>

    <div class="container">

        ```
        <div class="card-box">

            <h2 class="title">👥 Add New Customer</h2>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label>User</label>
                        @Html.DropDownList("UserID", null, "-- Select User --", new { @class = "form-control" })
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Branch</label>
                        @Html.DropDownList("BranchID", null, "-- Select Branch --", new { @class = "form-control" })
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>First Name</label>
                        @Html.TextBoxFor(m => m.FirstName, new { @class = "form-control" })
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Last Name</label>
                        @Html.TextBoxFor(m => m.LastName, new { @class = "form-control" })
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Father Name</label>
                        @Html.TextBoxFor(m => m.FatherName, new { @class = "form-control" })
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>CNIC</label>
                        @Html.TextBoxFor(m => m.CNIC, new { @class = "form-control", placeholder = "42101-1234567-1" })
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Gender</label>
                        @Html.DropDownListFor(m => m.Gender,
                            new List<SelectListItem>
                            {
                                new SelectListItem { Text = "Male", Value = "Male" },
                                new SelectListItem { Text = "Female", Value = "Female" }
                            },
                            "-- Select Gender --",
                            new { @class = "form-control" })
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Date of Birth</label>
                        @Html.TextBoxFor(m => m.DateOfBirth, "{0:yyyy-MM-dd}",
                            new { @class = "form-control", type = "date" })
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Phone</label>
                        @Html.TextBoxFor(m => m.Phone, new { @class = "form-control" })
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Email</label>
                        @Html.TextBoxFor(m => m.Email,
                            new { @class = "form-control", type = "email" })
                    </div>

                    <div class="col-md-12 mb-3">
                        <label>Address</label>
                        @Html.TextAreaFor(m => m.Address,
                            new { @class = "form-control", rows = "3" })
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Registration Date</label>
                        @Html.TextBoxFor(m => m.RegistrationDate, "{0:yyyy-MM-dd}",
                            new { @class = "form-control", type = "date" })
                    </div>

                </div>

                <button type="submit" class="btn-save">
                    ➕ Create Customer
                </button>

                <a href="/Customers/Index"
                   class="btn btn-outline-secondary btn-back">
                    ← Back to Customers
                </a>
            }

        </div>
        ```

    </div>

</body>
</html>
