@model WebApplication2.Models.Beneficiary

@{
    ViewBag.Title = "Beneficiary Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container py-4">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <!-- CARD -->
            <div class="card shadow-lg border-0 rounded-4">

                <!-- HEADER -->
                <div class="card-header bg-dark text-white text-center">
                    <h4 class="mb-0">👤 Beneficiary Details</h4>
                </div>

                <!-- BODY -->
                <div class="card-body p-4">

                    <div class="row g-3">

                        <!-- Nickname -->
                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">Nickname</small>
                                <div class="fw-semibold">
                                    @Model.NickName
                                </div>
                            </div>
                        </div>

                        <!-- Account Number -->
                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">Account Number</small>
                                <div class="fw-semibold">
                                    @Model.Account.AccountNumber
                                </div>
                            </div>
                        </div>

                        <!-- Customer Name -->
                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">Customer Name</small>
                                <div class="fw-semibold">
                                    @Model.Customer.CustomerID
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- BUTTONS -->
                    <div class="d-flex justify-content-between mt-4">

                        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                            ⬅ Back
                        </a>

                        <div>
                            <a href="@Url.Action("Edit", new { id = Model.BeneficiaryID })"
                               class="btn btn-warning">
                                ✏️ Edit
                            </a>
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>