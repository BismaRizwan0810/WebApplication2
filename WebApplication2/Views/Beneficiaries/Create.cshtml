@model WebApplication2.Models.Beneficiary

@{
    ViewBag.Title = "Create Beneficiary";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container py-4">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <!-- CARD -->
            <div class="card shadow-lg border-0 rounded-4">

                <!-- HEADER -->
                <div class="card-header bg-success text-white text-center">
                    <h4 class="mb-0">➕ Create Beneficiary</h4>
                </div>

                <!-- BODY -->
                <div class="card-body p-4">

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <!-- Customer -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Customer</label>
                            @Html.DropDownList("CustomerID", null, "Select Customer", new { @class = "form-select" })
                            @Html.ValidationMessageFor(model => model.CustomerID, "", new { @class = "text-danger" })
                        </div>

                        <!-- Beneficiary Account -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Beneficiary Account</label>
                            @Html.DropDownList("BeneficiaryAccountID", null, "Select Account", new { @class = "form-select" })
                            @Html.ValidationMessageFor(model => model.BeneficiaryAccountID, "", new { @class = "text-danger" })
                        </div>

                        <!-- Nickname -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nickname</label>
                            @Html.EditorFor(model => model.NickName, new { htmlAttributes = new { @class = "form-control", placeholder = "e.g Father, Friend, Office" } })
                            @Html.ValidationMessageFor(model => model.NickName, "", new { @class = "text-danger" })
                        </div>

                        <!-- BUTTONS -->
                        <div class="d-flex justify-content-between mt-4">

                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                                ⬅ Back
                            </a>

                            <button type="submit" class="btn btn-success px-4">
                                💾 Save Beneficiary
                            </button>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

</div>