@model IEnumerable<WebApplication2.Models.Beneficiary>

@{
    ViewBag.Title = "Beneficiaries";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary">👥 Beneficiaries</h2>
            <p class="text-muted mb-0">Manage saved transfer recipients</p>
        </div>

        <a href="@Url.Action("Create")" class="btn btn-success shadow-sm">
            ➕ Add Beneficiary
        </a>
    </div>

    <!-- CARD WRAPPER -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-dark">
                        <tr>
                            <th>Nickname</th>
                            <th>Account Number</th>
                            <th>Customer Name</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td class="fw-semibold">
                                    @item.NickName
                                </td>

                                <td>
                                    <span class="badge bg-secondary">
                                        @item.Account.AccountNumber
                                    </span>
                                </td>

                                <td>
                                    @item.Customer.FirstName
                                </td>

                                <td class="text-center">

                                    <a href="@Url.Action("Edit", new { id = item.BeneficiaryID })"
                                       class="btn btn-sm btn-warning me-1">
                                        Edit
                                    </a>

                                    <a href="@Url.Action("Details", new { id = item.BeneficiaryID })"
                                       class="btn btn-sm btn-info me-1">
                                        Details
                                    </a>

                                    <a href="@Url.Action("Delete", new { id = item.BeneficiaryID })"
                                       class="btn btn-sm btn-danger">
                                        Delete
                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>


    </div>
    <div class="mt-3">
        <a href="@Session["DashboardUrl"]" class="btn btn-secondary">
            ← Back To Dashboard
        </a>


    </div>
</div>