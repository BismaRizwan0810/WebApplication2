@model IEnumerable<WebApplication2.Models.Branch>

@{
    ViewBag.Title = "Branch Management";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">🏦 Branch Management</h2>

        <a href="@Url.Action("Create")" class="btn btn-success">
            ➕ Add Branch
        </a>
    </div>

    <!-- Success Message -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Error Message -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Card -->
    <div class="card shadow border-0">

        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">📋 Branch List</h5>
        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">
                        <tr>
                            <th>Branch Code</th>
                            <th>Branch Name</th>
                            <th>Address</th>
                            <th>City</th>
                            <th>Phone</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <td class="fw-semibold">@item.BranchCode</td>
                                    <td>@item.BranchName</td>
                                    <td>@item.Address</td>
                                    <td>@item.City</td>
                                    <td>@item.Phone</td>

                                    <td class="text-center">

                                        <div class="btn-group" role="group">

                                            <a href="@Url.Action("Edit", new { id = item.BranchID })"
                                               class="btn btn-warning btn-sm">
                                                ✏ Edit
                                            </a>

                                            <a href="@Url.Action("Details", new { id = item.BranchID })"
                                               class="btn btn-info btn-sm">
                                                👁 Details
                                            </a>

                                            <a href="@Url.Action("Delete", new { id = item.BranchID })"
                                               class="btn btn-danger btn-sm">
                                                🗑 Delete
                                            </a>

                                        </div>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    No branches found.
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>
            <div class="mt-3">
                <a href="/Admin/Dashboard" class="btn btn-secondary">
                    ← Back To Dashboard
                </a>


            </div>
        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>