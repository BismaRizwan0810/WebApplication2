@model WebApplication2.Models.Branch

@{
    ViewBag.Title = "Branch Details";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-md-10 col-lg-8">

            <div class="card shadow-lg border-0 rounded-3">

                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0">🏦 Branch Details</h4>
                </div>

                <div class="card-body p-4">

                    <div class="row g-3">

                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">Branch Code</small>
                                <div class="fw-semibold">@Model.BranchCode</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">Branch Name</small>
                                <div class="fw-semibold">@Model.BranchName</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">Address</small>
                                <div class="fw-semibold">@Model.Address</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">City</small>
                                <div class="fw-semibold">@Model.City</div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">Phone</small>
                                <div class="fw-semibold">@Model.Phone</div>
                            </div>
                        </div>

                    </div>

                    <div class="d-flex justify-content-between mt-4">

                        <a href="@Url.Action("Index")"
                           class="btn btn-outline-secondary">
                            ⬅ Back
                        </a>

                        <a href="@Url.Action("Edit", new { id = Model.BranchID })"
                           class="btn btn-primary">
                            ✏️ Edit Branch
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>