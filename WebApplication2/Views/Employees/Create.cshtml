@model WebApplication2.Models.Employee

@{
    ViewBag.Title = "Create Employee";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-md-10 col-lg-8">

            <div class="card shadow-lg border-0 rounded-3">

                <div class="card-header bg-success text-white text-center">
                    <h4 class="mb-0">➕ Create Employee</h4>
                </div>

                <div class="card-body p-4">

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <div class="row">

                            <!-- Branch -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Branch</label>
                                @Html.DropDownList("BranchID", null, new { @class = "form-select" })
                                @Html.ValidationMessageFor(model => model.BranchID, "", new { @class = "text-danger" })
                            </div>

                            <!-- First Name -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">First Name</label>
                                @Html.EditorFor(model => model.FirstName, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.FirstName, "", new { @class = "text-danger" })
                            </div>

                            <!-- Last Name -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Last Name</label>
                                @Html.EditorFor(model => model.LastName, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.LastName, "", new { @class = "text-danger" })
                            </div>

                            <!-- CNIC -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">CNIC</label>
                                @Html.EditorFor(model => model.CNIC, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.CNIC, "", new { @class = "text-danger" })
                            </div>

                            <!-- Designation -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Designation</label>
                                @Html.EditorFor(model => model.Designation, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.Designation, "", new { @class = "text-danger" })
                            </div>

                            <!-- Salary -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Salary</label>
                                @Html.EditorFor(model => model.Salary, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.Salary, "", new { @class = "text-danger" })
                            </div>

                            <!-- Phone -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Phone</label>
                                @Html.EditorFor(model => model.Phone, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.Phone, "", new { @class = "text-danger" })
                            </div>

                            <!-- Email -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Email</label>
                                @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger" })
                            </div>

                            <!-- Hire Date -->
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Hire Date</label>
                                @Html.EditorFor(model => model.HireDate, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.HireDate, "", new { @class = "text-danger" })
                            </div>

                        </div>

                        <!-- Buttons -->
                        <div class="d-flex justify-content-between mt-4">

                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                                ⬅ Back
                            </a>

                            <button type="submit" class="btn btn-success">
                                💾 Save Employee
                            </button>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

</div>