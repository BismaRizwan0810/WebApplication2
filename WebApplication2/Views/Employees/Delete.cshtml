@model WebApplication2.Models.Employee

@{
    ViewBag.Title = "Delete Employee";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-md-10 col-lg-8">

            <!-- Danger Card -->
            <div class="card shadow-lg border-0 rounded-3">

                <div class="card-header bg-danger text-white text-center">
                    <h4 class="mb-0">⚠️ Delete Employee</h4>
                </div>

                <div class="card-body p-4">

                    <div class="alert alert-warning">
                        <strong>Warning:</strong> Are you sure you want to delete this employee? This action cannot be undone.
                    </div>

                    <!-- Employee Info -->
                    <div class="row g-3 mb-4">

                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">First Name</small>
                                <div class="fw-semibold">@Model.FirstName</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">Last Name</small>
                                <div class="fw-semibold">@Model.LastName</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">CNIC</small>
                                <div class="fw-semibold">@Model.CNIC</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">Designation</small>
                                <div class="fw-semibold">@Model.Designation</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">Salary</small>
                                <div class="fw-semibold">@Model.Salary</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">Phone</small>
                                <div class="fw-semibold">@Model.Phone</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">Email</small>
                                <div class="fw-semibold">@Model.Email</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">Hire Date</small>
                                <div class="fw-semibold">@Model.HireDate</div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="border rounded p-3 bg-light">
                                <small class="text-muted">Branch Code</small>
                                <div class="fw-semibold">@Model.Branch?.BranchCode</div>
                            </div>
                        </div>

                    </div>

                    <!-- Delete Form -->
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()

                        <div class="d-flex justify-content-between">

                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                                ⬅ Cancel
                            </a>

                            <button type="submit" class="btn btn-danger">
                                🗑 Confirm Delete
                            </button>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

</div>