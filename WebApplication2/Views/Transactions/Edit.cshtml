@model WebApplication2.Models.Transaction

@{
    ViewBag.Title = "Edit Transaction";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">

    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">

            <!-- CARD -->
            <div class="card border-0 shadow-lg rounded-4">

                <!-- HEADER -->
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0 fw-bold">✏️ Edit Transaction</h4>
                </div>

                <!-- BODY -->
                <div class="card-body p-4">

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()

                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        @Html.HiddenFor(model => model.TransactionID)

                        <!-- Account -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Account</label>
                            @Html.DropDownList("AccountID", null, "-- Select Account --", new { @class = "form-select form-select-lg" })
                            @Html.ValidationMessageFor(model => model.AccountID, "", new { @class = "text-danger" })
                        </div>

                        <!-- Transaction Type -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Transaction Type</label>
                            @Html.DropDownList("TransactionTypeID", null, "-- Select Type --", new { @class = "form-select form-select-lg" })
                            @Html.ValidationMessageFor(model => model.TransactionTypeID, "", new { @class = "text-danger" })
                        </div>

                        <!-- Amount -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Amount</label>
                            @Html.TextBoxFor(model => model.Amount, new { @class = "form-control form-control-lg", placeholder = "Enter amount" })
                            @Html.ValidationMessageFor(model => model.Amount, "", new { @class = "text-danger" })
                        </div>

                        <!-- Description -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Description</label>
                            @Html.TextAreaFor(model => model.Description, new { @class = "form-control", rows = 3, placeholder = "Enter description" })
                            @Html.ValidationMessageFor(model => model.Description, "", new { @class = "text-danger" })
                        </div>

                        <!-- Date -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Transaction Date</label>
                            @Html.TextBoxFor(model => model.TransactionDate, "{0:yyyy-MM-dd}", new { @class = "form-control form-control-lg", type = "date" })
                            @Html.ValidationMessageFor(model => model.TransactionDate, "", new { @class = "text-danger" })
                        </div>

                        <!-- BUTTONS -->
                        <div class="d-flex justify-content-between">

                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary px-4">
                                ← Back
                            </a>

                            <button type="submit" class="btn btn-success px-4 shadow-sm">
                                💾 Save Changes
                            </button>

                        </div>
                    }

                </div>
            </div>

        </div>
    </div>

</div>