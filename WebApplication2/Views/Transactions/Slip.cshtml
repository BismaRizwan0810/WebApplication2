@model WebApplication2.Models.Transaction

@{
    ViewBag.Title = "Transaction Slip";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Transaction Slip</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        .slip {
            width: 600px;
            margin: 30px auto;
            border: 2px solid #000;
            padding: 20px;
            background: white;
        }

        .title {
            text-align: center;
            margin-bottom: 20px;
        }

        @@media print {
            .no-print {
                display: none;
            }
        }
    </style>
</head>
<body>

    <div class="slip">

        <h2 class="title">BANK TRANSACTION SLIP</h2>

        <hr />

        <p>
            <strong>Transaction ID:</strong>
            @Model.TransactionID
        </p>

        <p>
            <strong>Amount:</strong>
            Rs. @Model.Amount
        </p>

        <p>
            <strong>Date:</strong>
            @Model.TransactionDate
        </p>

        <p>
            <strong>Type:</strong>

            @if (Model.TransactionType != null)
            {
                @Model.TransactionType.TypeName
            }
            else
            {
                <span>N/A</span>
            }
        </p>

        <p>
            <strong>Status:</strong>
            Successful
        </p>

        <hr />

        <div class="no-print">
            <button onclick="window.print()" class="btn btn-success">
                Print
            </button>

            <a href="/Transactions/GenerateSlip"
               class="btn btn-secondary">
                Back
            </a>
        </div>

    </div>

</body>
</html>