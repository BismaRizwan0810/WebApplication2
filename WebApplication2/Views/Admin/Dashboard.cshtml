@{
    ViewBag.Title = "Admin Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Admin Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            background: #f4f7fc;
            font-family: 'Segoe UI';
        }

        .sidebar {
            position: fixed;
            width: 250px;
            height: 100vh;
            background: #1e3a8a;
            color: white;
            padding-top: 20px;
            overflow-y: auto;
        }

            .sidebar h3 {
                text-align: center;
                margin-bottom: 30px;
            }

            .sidebar a {
                display: block;
                color: white;
                text-decoration: none;
                padding: 14px 25px;
                transition: 0.3s;
            }

                .sidebar a:hover {
                    background: #2563eb;
                }

        .content {
            margin-left: 250px;
            padding: 30px;
        }

        .welcome-box {
            background: white;
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 25px;
            box-shadow: 0px 3px 10px rgba(0,0,0,0.1);
        }

        .card-box {
            border-radius: 15px;
            color: white;
            padding: 25px;
            text-align: center;
            box-shadow: 0px 5px 15px rgba(0,0,0,.1);
        }

            .card-box h2 {
                margin: 0;
                font-size: 35px;
                font-weight: bold;
            }

            .card-box p {
                margin-top: 10px;
                font-size: 16px;
            }

        .quick-actions {
            background: white;
            padding: 20px;
            margin-top: 30px;
            border-radius: 15px;
            box-shadow: 0px 3px 10px rgba(0,0,0,0.1);
        }

            .quick-actions .btn {
                margin: 5px;
            }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <div class="sidebar">

        <h3>🏦 BMS Admin</h3>

        <a href="/Admin/Dashboard">📊 Dashboard</a>

        <a href="/Users/Index">👤 Manage Users</a>

        <a href="/Employees/Index">👨‍💼 Manage Employees</a>

        <a href="/Customers/Index">👥 Manage Customers</a>

        <a href="/Accounts/Index">🏦 Accounts</a>

        <a href="/Transactions/Index">💳 Transactions</a>

        <a href="/Loans/Index">💰 Loans</a>

        <a href="/Branches/Index">🏢 Branches</a>

        <a href="/DebitCards/Index">💳 Debit Cards</a>

        <a href="/Beneficiaries/Index">👨‍👩‍👧 Beneficiaries</a>

        <a href="/CustomerDocuments/Index">📄 Documents</a>

        <a href="/Home/Logout">🚪 Logout</a>

    </div>

    <!-- Main Content -->
    <div class="content">

        <div class="welcome-box">
            <h2>Welcome Admin 👋</h2>

            <p>
                Manage Users, Employees, Customers,
                Accounts, Transactions, Loans and
                other banking operations from one place.
            </p>
        </div>

        <!-- Statistics -->
        <div class="row g-4">

            <div class="col-md-4">
                <div class="card-box bg-primary">
                    <h2>@ViewBag.TotalUsers</h2>
                    <p>Total Users</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-box bg-dark">
                    <h2>@ViewBag.TotalEmployees</h2>
                    <p>Total Employees</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-box bg-success">
                    <h2>@ViewBag.TotalCustomers</h2>
                    <p>Total Customers</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-box bg-warning">
                    <h2>@ViewBag.TotalAccounts</h2>
                    <p>Total Accounts</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-box bg-info">
                    <h2>@ViewBag.TotalTransactions</h2>
                    <p>Total Transactions</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-box bg-danger">
                    <h2>@ViewBag.TotalLoans</h2>
                    <p>Total Loans</p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card-box bg-secondary">
                    <h2>@ViewBag.TotalBranches</h2>
                    <p>Total Branches</p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card-box bg-success">
                    <h2>@ViewBag.TotalDebitCards</h2>
                    <p>Debit Cards</p>
                </div>
            </div>

        </div>

        <!-- Quick Actions -->
        <div class="quick-actions">

            <h4>⚡ Quick Actions</h4>

            <hr />

            <a href="/Users/Create" class="btn btn-primary">
                ➕ Add User
            </a>

            <a href="/Employees/Create" class="btn btn-dark">
                👨‍💼 Add Employee
            </a>

            <a href="/Customers/Create" class="btn btn-warning">
                👥 Add Customer
            </a>

            <a href="/Accounts/Create" class="btn btn-info">
                🏦 Open Account
            </a>

            <a href="/Transactions/Create" class="btn btn-primary">
                💳 New Transaction
            </a>

            <a href="/Loans/Create" class="btn btn-danger">
                💰 New Loan
            </a>

            <a href="/Branches/Create" class="btn btn-secondary">
                🏢 Add Branch
            </a>

            <a href="/DebitCards/Create" class="btn btn-success">
                💳 Issue Card
            </a>

        </div>

    </div>

</body>
</html>