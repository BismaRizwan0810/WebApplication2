@model IEnumerable<WebApplication2.Models.User>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        background: #f1f5f9;
        font-family: Segoe UI;
    }

    .container-box {
        margin: 30px auto;
        padding: 20px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    }

    .title {
        font-size: 28px;
        font-weight: bold;
        color: #1e3a8a;
    }

    .btn-custom {
        background: #2563eb;
        color: white;
        border-radius: 8px;
    }

        .btn-custom:hover {
            background: #1d4ed8;
            color: white;
        }

    table thead {
        background: #1e3a8a;
        color: white;
    }

    .badge-active {
        background: #16a34a;
    }

    .badge-inactive {
        background: #dc2626;
    }
</style>

<div class="container container-box">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="title">👤 Users Management</div>
        <a href="/Users/Create" class="btn btn-custom">➕ Add New User</a>
    </div>

    <table class="table table-hover table-bordered align-middle">

        <thead>
            <tr>
                <th>ID</th>
                <th>Username</th>
                <th>Email</th>
                <th>Password</th>
                <th>Status</th>
                <th>Created</th>
                <th>Role</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.UserID</td>
                    <td><b>@item.Username</b></td>
                    <td>@item.Email</td>
                    <td>••••••</td>

                    <td>
                        @if (item.IsActive == true)
                        {
                            <span class="badge badge-active">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-inactive">Inactive</span>
                        }
                    </td>

                    <td>@item.CreatedAt</td>
                    <td>@item.Role.RoleName</td>

                    <td>
                        <a href="/Users/Edit/@item.UserID" class="btn btn-warning btn-sm">Edit</a>
                        <a href="/Users/Details/@item.UserID" class="btn btn-info btn-sm">Details</a>

                        <a href="/Users/Delete/@item.UserID"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Are you sure you want to delete this user?');">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>

    </table>
    

    <div class="mt-3">
        <a href="/Admin/Dashboard" class="btn btn-secondary">
            ← Back To Dashboard
        </a>
    </div>

</div>

